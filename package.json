{
  "name": "vm-worker",
  "version": "1.2.1",
  "description": "Tiny virtual machine for browser to execute javascript modules in Web Worker",
  "keywords": [
    "virtual",
    "machine",
    "vm",
    "eval",
    "exec",
    "execute",
    "browser",
    "web",
    "worker",
    "webworker",
    "module",
    "esm",
    "esmodule",
    "commonjs",
    "typescript",
    "ts",
    "import",
    "export",
    "exports",
    "require"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cweili/vm-worker.git"
  },
  "author": "Cweili",
  "license": "MIT",
  "homepage": "https://github.com/Cweili/vm-worker",
  "bugs": {
    "url": "https://github.com/Cweili/vm-worker/issues"
  },
  "type": "module",
  "main": "dist/vm-worker.cjs.js",
  "module": "dist/vm-worker.esm.js",
  "unpkg": "dist/vm-worker.js",
  "jsdelivr": "dist/vm-worker.js",
  "exports": {
    ".": {
      "import": "./dist/vm-worker.esm.js",
      "require": "./dist/vm-worker.cjs.js",
      "default": "./dist/vm-worker.js"
    },
    "./esmodule": {
      "import": "./dist/plugins/esmodule.esm.js",
      "require": "./dist/plugins/esmodule.cjs.js",
      "default": "./dist/plugins/esmodule.js"
    },
    "./sucrase": {
      "import": "./dist/plugins/sucrase.esm.js",
      "require": "./dist/plugins/sucrase.cjs.js",
      "default": "./dist/plugins/sucrase.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build:clean": "node -e \"const fs=require('fs'); if(fs.existsSync('dist')) fs.rmSync('dist',{recursive:true})\"",
    "build:workers": "node scripts/build-workers.mjs",
    "build:main": "vite build",
    "build": "npm run build:clean && npm run build:workers && npm run build:main",
    "build:docs": "vite build --config vite.docs.config.ts",
    "dev": "vite --config vite.docs.config.ts",
    "lint": "eslint src/",
    "test": "node --import ./test-loader.js --test tests/*.test.js",
    "test:coverage": "node --import ./test-loader.js --test --experimental-test-coverage tests/*.test.js",
    "test:ci": "node -e \"require('fs').mkdirSync('coverage',{recursive:true})\" && node --import ./test-loader.js --test --experimental-test-coverage --test-reporter spec --test-reporter lcov --test-reporter-destination stdout --test-reporter-destination coverage/lcov.info tests/*.test.js"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/prismjs": "^1.26.6",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "mitt": "^3.0.0",
    "prismjs": "^1.30.0",
    "rewrite-imports": "^3.0.0",
    "solid-js": "^1.9.13",
    "sucrase": "^3.24.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12"
  }
}
